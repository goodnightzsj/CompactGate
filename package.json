{
  "name": "compactgate",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Local OpenAI-compatible reverse proxy with compact request routing and model rewriting.",
  "scripts": {
    "dev": "tsx watch src/server/main.ts",
    "build": "tsc -p tsconfig.json && tsc -p tsconfig.server.json && vite build",
    "start": "node dist/server/main.js",
    "restart": "bash scripts/restart-service.sh",
    "service:restart": "bash scripts/restart-service.sh",
    "test": "vitest run test/config.test.ts test/routing.test.ts test/primary-failover.test.ts test/server.test.ts test/usage.test.ts",
    "test:watch": "vitest",
    "stop": "bash scripts/stop-service.sh",
    "service:stop": "bash scripts/stop-service.sh"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^5.1.1",
    "vite": "^7.2.7",
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.15"
  },
  "engines": {
    "node": ">=20.11"
  }
}
